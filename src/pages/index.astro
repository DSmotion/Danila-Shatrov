---
import Layout from "@layouts/Layout.astro";
import Header from "@components/common/header/Header.astro";
import Hero from "@components/home/Hero.astro";
import VideoBlock from "@components/home/VideoBlock.astro";
import ServicesBlock from "@components/home/ServicesBlock.astro";
import StepsBlock from "@components/home/StepsBlock.astro";
import QuestionsBlock from "@components/home/QuestionsBlock.astro";
---

<Layout>
  <div class="bg-black min-h-screen flex flex-col">
    <Header />
    <Hero />
    <VideoBlock />
    <ServicesBlock />
    <StepsBlock />
    <QuestionsBlock />
  </div>
</Layout>

<style>
  .main {
    position: relative;
    min-height: 1024px;
  }

  .hero-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    object-fit: cover;
  }
</style>
